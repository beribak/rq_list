<div class="app-container content-section">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="form-shell">
      <p class="eyebrow"><%= t("menu_items.form.eyebrow") %></p>
      <h1><%= @menu_item.persisted? ? t("menu_items.form.title_edit") : t("menu_items.form.title_new") %></h1>
      <p class="section-subtitle">
        <%= t("menu_items.form.subtitle_prefix_menu") %> <%= @section.menu.name %> › <%= t("menu_items.form.subtitle_prefix_section") %> <%= @section.name %>
      </p>

      <%= simple_form_for [@section, @menu_item] do |f| %>
        <%= f.input :name, 
            label: t("menu_items.form.name_label"),
            placeholder: t("menu_items.form.name_placeholder"),
            input_html: { class: "form-control" } %>
        
        <%= f.input :description, 
            label: t("menu_items.form.description_label"),
            as: :text,
            placeholder: t("menu_items.form.description_placeholder"),
            input_html: { rows: 3, class: "form-control" } %>

        <%= f.input :price,
            label: t("menu_items.form.price_label"),
            placeholder: t("menu_items.form.price_placeholder"),
            input_html: { class: "form-control", step: "0.01" } %>

        <%= f.input :position,
            label: t("menu_items.form.position_label"),
            hint: t("menu_items.form.position_hint"),
            input_html: { class: "form-control" } %>

        <div class="d-flex gap-2 mt-4 flex-wrap">
          <%= f.button :submit, class: "btn btn-primary" %>
          <%= link_to t("menu_items.form.cancel"), menu_path(@section.menu), class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
      </div>
    </div>
  </div>
</div>
