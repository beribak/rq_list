<div class="app-container content-section">
  <div class="auth-shell">
    <div class="auth-copy">
      <p class="eyebrow"><%= t("devise.shared.welcome_back") %></p>
      <h1>Log in</h1>
      <p class="section-subtitle"><%= t("devise.shared.login_subtitle") %></p>
    </div>

    <div class="form-shell auth-form-shell">
      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="form-inputs">
          <%= f.input :email,
                      required: false,
                      autofocus: true,
                      input_html: { autocomplete: "email" } %>
          <%= f.input :password,
                      required: false,
                      input_html: { autocomplete: "current-password" } %>
          <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
        </div>

        <div class="form-actions">
          <%= f.button :submit, "Log in", class: "btn btn-primary w-100" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
