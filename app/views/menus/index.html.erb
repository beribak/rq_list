<div class="app-container content-section">
  <div class="section-heading d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-end gap-3 mb-4">
    <div>
      <p class="eyebrow"><%= t("menus.index.eyebrow") %></p>
      <h1><%= t("menus.index.title") %></h1>
      <p class="section-subtitle"><%= t("menus.index.subtitle") %></p>
    </div>
    <%= link_to new_menu_path, class: "btn-icon btn-icon-add" do %>
      <i class="bi bi-plus-lg"></i>
      <span><%= t('menus.index.create_new') %></span>
    <% end %>
  </div>

  <% if @menus.any? %>
    <div class="row g-4">
      <% @menus.each do |menu| %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 menu-card studio-card studio-card-sharp">
            <%= link_to menu_path(menu), class: "text-decoration-none" do %>
              <div class="card-body">
                <p class="card-kicker"><%= t("menus.index.deck_label") %></p>
                <h5 class="card-title"><%= menu.name_translated %></h5>
                <p class="card-text text-muted"><%= truncate(menu.description_translated, length: 100) %></p>
                <p class="text-muted small mb-0">
                  <i class="bi bi-layout-text-sidebar"></i> <%= menu.sections.count %> <%= t('menus.index.sections') %>
                </p>
              </div>
            <% end %>
            <div class="card-footer">
              <div class="menu-card-actions">
                <%= link_to edit_menu_path(menu), class: "icon-action", aria: { label: "Edit menu" } do %>
                  <i class="bi bi-pencil-fill"></i>
                <% end %>
                <%= button_to menu_path(menu), method: :delete, 
                    data: { turbo_confirm: t('menus.index.delete_confirm') }, 
                    class: "icon-action-danger", aria: { label: "Delete menu" } do %>
                  <i class="bi bi-trash-fill"></i>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info panel-alert">
      <p class="mb-0"><%= t('menus.index.no_menus') %> <%= link_to t('menus.index.create_first'), new_menu_path, class: "alert-link" %>!</p>
    </div>
  <% end %>
</div>
