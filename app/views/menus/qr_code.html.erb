<div class="app-container content-section">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card qr-card">
        <div class="card-header">
          <p class="card-kicker mb-2"><%= t("menus.qr_code.eyebrow") %></p>
          <h2 class="mb-0"><%= t('menus.qr_code.title', name: @menu.name) %></h2>
        </div>
        <div class="card-body text-center">
          <p class="section-subtitle mb-4"><%= t('menus.qr_code.scan_message') %></p>
          
          <div class="mb-4 qr-frame">
            <%= @qr.as_svg(
              color: "000",
              shape_rendering: "crispEdges",
              module_size: 6,
              standalone: true,
              use_path: true
            ).html_safe %>
          </div>

          <div class="d-flex gap-2 justify-content-center flex-wrap">
            <%= link_to t('menus.qr_code.download_svg'), qr_code_menu_path(@menu, format: :svg), 
                class: "btn btn-primary", 
                download: "#{@menu.name.parameterize}-qr.svg" %>
            <%= link_to t('menus.qr_code.download_png'), qr_code_menu_path(@menu, format: :png), 
                class: "btn btn-success", 
                download: "#{@menu.name.parameterize}-qr.png" %>
            <%= link_to t('menus.qr_code.back_to_menu'), menu_path(@menu), class: "btn btn-outline-secondary" %>
          </div>

          <div class="mt-4">
            <p class="text-muted small mb-0">
              <%= t('menus.qr_code.links_to') %>
              <%= link_to public_menu_url(@menu), public_menu_url(@menu), class: "text-decoration-underline", target: "_blank", rel: "noopener" %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
