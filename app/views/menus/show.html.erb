<div class="app-container content-section">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
    <div>
      <h1><%= @menu.name_translated %></h1>
      <p class="section-subtitle"><%= @menu.description_translated %></p>
    </div>
    <div class="d-flex gap-2 flex-nowrap">
      <%= link_to qr_code_menu_path(@menu), class: "btn-icon btn-icon-info" do %>
        <i class="bi bi-qr-code"></i>
        <span><%= t('menus.show.qr_code') %></span>
      <% end %>
      <%= link_to edit_menu_path(@menu), class: "icon-action", aria: { label: "Edit menu" } do %>
        <i class="bi bi-pencil-fill"></i>
      <% end %>
      <%= link_to menus_path, class: "btn-icon btn-icon-secondary" do %>
        <i class="bi bi-arrow-left"></i>
      <% end %>
    </div>
  </div>

  <div class="mb-3">
    <%= link_to new_menu_section_path(@menu), class: "btn-icon btn-icon-add" do %>
      <i class="bi bi-plus-lg"></i>
      <span><%= t('menus.show.add_section') %></span>
    <% end %>
  </div>

  <% if @sections.any? %>
    <nav class="menu-section-nav" aria-label="Menu sections">
      <div class="menu-section-nav-track">
        <% @sections.each do |section| %>
          <%= link_to "##{dom_id(section, :menu_section)}", class: "menu-section-nav-link" do %>
            <span><%= section.name_translated %></span>
          <% end %>
        <% end %>
      </div>
    </nav>

    <div class="menu-sheet menu-sheet-admin">
      <% @sections.each do |section| %>
        <section id="<%= dom_id(section, :menu_section) %>" class="menu-section-block">
          <div class="menu-section-top">
            <div class="menu-section-heading">
              <h2><%= section.name_translated %></h2>
              <span class="menu-section-underline"></span>
            </div>
            <div class="menu-section-actions">
              <%= link_to edit_menu_section_path(@menu, section), class: "icon-action", aria: { label: "Edit section" } do %>
                <i class="bi bi-pencil-fill"></i>
              <% end %>
              <%= button_to menu_section_path(@menu, section), method: :delete,
                  data: { turbo_confirm: t('menus.show.delete_confirm') }, class: "icon-action-danger", aria: { label: "Delete section" } do %>
                <i class="bi bi-trash-fill"></i>
              <% end %>
              <%= link_to new_section_menu_item_path(section), class: "icon-action", aria: { label: "Add item" } do %>
                <i class="bi bi-patch-plus-fill"></i>
              <% end %>
            </div>
          </div>

          <% if section.description.present? %>
            <p class="menu-section-description"><%= section.description %></p>
          <% end %>

          <% if section.menu_items.any? %>
            <div class="menu-list">
              <% section.menu_items.each do |item| %>
                <article class="menu-list-item">
                  <div class="menu-item-image">
                    <%= image_tag "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200&h=200&fit=crop", alt: item.name_translated, class: "item-img" %>
                  </div>
                  <div class="menu-item-content">
                    <div class="menu-item-header">
                      <div class="menu-item-title-wrap">
                        <h5 class="menu-item-name"><%= item.name_translated %></h5>
                        <span class="menu-item-rule"></span>
                      </div>
                      <% if item.price.present? %>
                        <span class="menu-item-price">$<%= number_with_precision(item.price, precision: 2) %></span>
                      <% end %>
                    </div>
                    <% if item.description.present? %>
                      <p class="menu-item-description"><%= item.description_translated %></p>
                    <% end %>
                    <div class="menu-item-actions">
                      <%= link_to edit_section_menu_item_path(section, item), class: "icon-action", aria: { label: "Edit item" } do %>
                        <i class="bi bi-pencil-fill"></i>
                      <% end %>
                      <%= button_to section_menu_item_path(section, item), method: :delete,
                          data: { turbo_confirm: t('menus.show.delete_confirm') }, class: "icon-action-danger", aria: { label: "Delete item" } do %>
                        <i class="bi bi-trash-fill"></i>
                      <% end %>
                    </div>
                  </div>
                </article>
              <% end %>
            </div>
          <% else %>
            <p class="menu-empty-note"><%= t('menus.show.no_items') %></p>
          <% end %>
        </section>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info panel-alert">
      <p class="mb-0"><%= t('menus.show.no_sections') %> <%= link_to t('menus.show.add_first_section'), new_menu_section_path(@menu), class: "alert-link" %>!</p>
    </div>
  <% end %>
</div>
